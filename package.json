{
  "name": "cognitive-engine",
  "private": true,
  "description": "TypeScript framework for building AI agents with cognitive capabilities",
  "author": "Dmitry Zorin",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/medonomator/cognitive-engine.git"
  },
  "homepage": "https://github.com/medonomator/cognitive-engine",
  "keywords": [
    "ai",
    "agents",
    "cognitive-architecture",
    "bdi",
    "thompson-sampling",
    "episodic-memory",
    "perception",
    "reasoning",
    "typescript"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "typecheck": "turbo run build",
    "test:ci": "vitest run --reporter=verbose",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.5.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
